# Demo / production server
PORT=5173
CACHOU_PORT=5173

# Set to 1 to enable demo-only privileged APIs (todos, files, raw db helpers).
# Never enable this on a public production host.
CACHOU_DEMO=0

# Database adapter: sqlite | memory | postgres | mysql | mongodb | firebase
CACHOU_DB_TYPE=sqlite

# Files API root (defaults to ./sandbox when demo mode is on)
CACHOU_FILES_ROOT=./sandbox
CACHOU_FILES_MAX_BYTES=1048576

# Optional external backend for Vite proxy
# CACHOU_BACKEND_URL=http://localhost:3001
