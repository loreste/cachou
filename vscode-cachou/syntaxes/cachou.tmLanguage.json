{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Cachou",
  "scopeName": "source.cachou",
  "patterns": [
    { "include": "#script-block" },
    { "include": "#style-block" },
    { "include": "#comment" },
    { "include": "#expression" },
    { "include": "#tag" },
    { "include": "text.html.basic" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.block.html",
          "begin": "<!--",
          "end": "-->"
        }
      ]
    },
    "script-block": {
      "name": "meta.block.script.cachou",
      "begin": "(?i)(<)(script)(?![\\w:-])",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.script.html" }
      },
      "end": "(?i)(</)(script)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.script.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "patterns": [
        {
          "begin": "(>)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.end.html" }
          },
          "end": "(?i)(?=</script>)",
          "name": "source.js.embedded.cachou",
          "patterns": [{ "include": "source.js" }]
        },
        { "include": "#tag-attributes" }
      ]
    },
    "style-block": {
      "name": "meta.block.style.cachou",
      "begin": "(?i)(<)(style)(?![\\w:-])",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.style.html" }
      },
      "end": "(?i)(</)(style)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.style.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "patterns": [
        {
          "begin": "(>)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.end.html" }
          },
          "end": "(?i)(?=</style>)",
          "name": "source.css.embedded.cachou",
          "patterns": [
            {
              "name": "entity.other.attribute-name.pseudo-class.css.cachou",
              "match": ":(host|global)\\b"
            },
            { "include": "source.css" }
          ]
        },
        {
          "name": "entity.other.attribute-name.html",
          "match": "\\bscoped\\b"
        },
        { "include": "#tag-attributes" }
      ]
    },
    "expression": {
      "name": "meta.embedded.expression.js.cachou",
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.cachou" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.cachou" }
      },
      "patterns": [
        { "include": "#balanced-braces" },
        { "include": "source.js" }
      ]
    },
    "balanced-braces": {
      "begin": "\\{",
      "end": "\\}",
      "patterns": [
        { "include": "#balanced-braces" },
        { "include": "source.js" }
      ]
    },
    "tag": {
      "patterns": [
        {
          "name": "meta.tag.other.cachou",
          "begin": "(</?)([A-Za-z][\\w:-]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.html" },
            "2": { "name": "entity.name.tag.html" }
          },
          "end": "(/?>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.end.html" }
          },
          "patterns": [
            { "include": "#expression" },
            { "include": "#tag-attributes" }
          ]
        }
      ]
    },
    "tag-attributes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.html",
          "match": "\\b(class|style|ref|transition|bind:[\\w-]+|class:[\\w-]+|style:[\\w-]+|on[a-z]+|\\.[\\w-]+|[\\w-:\\.]+)\\b"
        },
        {
          "name": "string.quoted.double.html",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "include": "#expression" }]
        },
        {
          "name": "string.quoted.single.html",
          "begin": "'",
          "end": "'",
          "patterns": [{ "include": "#expression" }]
        },
        {
          "name": "meta.attribute.unquoted.expression.cachou",
          "begin": "(=)\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "punctuation.separator.key-value.html" },
            "2": { "name": "punctuation.section.embedded.begin.cachou" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.embedded.end.cachou" }
          },
          "patterns": [
            { "include": "#balanced-braces" },
            { "include": "source.js" }
          ]
        }
      ]
    }
  }
}
