{
  "name": "cachou-faydb-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CRM proving ground built with CachouJS and FayDB.",
  "scripts": {
    "compile": "npm --prefix .. run crm:compile",
    "dev": "npm run compile && node ../node_modules/vite/bin/vite.js --host 127.0.0.1 --port 5190",
    "build": "npm run compile && node ../node_modules/vite/bin/vite.js build",
    "preview": "node ../node_modules/vite/bin/vite.js preview --host 127.0.0.1 --port 5190",
    "api": "node server.mjs",
    "api:faydb": "FAYDB_MODE=faydb node server.mjs",
    "api:postgres": "FAYDB_MODE=faydb FAYDB_DSN=postgres://crm:crm@127.0.0.1:55433/faydb?sslmode=disable node server.mjs",
    "demo": "node scripts/start-demo.mjs",
    "check": "npm run compile && node scripts/check.mjs",
    "smoke": "node scripts/smoke.mjs",
    "smoke:faydb": "FAYDB_MODE=faydb node scripts/smoke.mjs",
    "smoke:postgres": "FAYDB_MODE=faydb FAYDB_DSN=postgres://crm:crm@127.0.0.1:55433/faydb?sslmode=disable node scripts/smoke.mjs",
    "ui:smoke": "node scripts/ui-smoke.mjs",
    "visual:smoke": "node scripts/visual-smoke.mjs",
    "visual:baseline": "CRM_UPDATE_VISUAL_BASELINE=1 node scripts/visual-smoke.mjs",
    "stress": "node scripts/stress.mjs",
    "stress:faydb": "FAYDB_MODE=faydb node scripts/stress.mjs",
    "qa": "node scripts/qa.mjs",
    "ci": "node scripts/ci-artifacts.mjs",
    "bench:report": "CACHOU_COMPARE_REPORT_PATH=faydb-crm/artifacts/benchmarks/latest.json npm --prefix .. run bench:compare",
    "demo:reset": "node scripts/reset-demo-data.mjs",
    "db:postgres:up": "docker run --name cachou-crm-postgres -e POSTGRES_USER=crm -e POSTGRES_PASSWORD=crm -e POSTGRES_DB=faydb -p 55433:5432 -d postgres:16-alpine",
    "db:postgres:start": "docker start cachou-crm-postgres",
    "db:postgres:stop": "docker stop cachou-crm-postgres"
  },
  "dependencies": {
    "pg": "^8.16.3",
    "ws": "^8.21.0"
  }
}
