<style scoped>
  .modal {
    align-items: center;
    background: rgba(16, 22, 36, 0.58);
    display: flex;
    inset: 0;
    justify-content: center;
    padding: 20px;
    position: fixed;
    z-index: 20;
  }

  .editor {
    background: rgba(255, 255, 255, 0.98);
    border: 1px solid rgba(117, 139, 160, 0.24);
    border-radius: 14px;
    box-shadow: 0 28px 80px rgba(16, 22, 36, 0.22);
    display: grid;
    gap: 12px;
    max-width: 560px;
    padding: 22px;
    width: min(560px, 100%);
  }

  header,
  footer {
    align-items: center;
    display: flex;
    justify-content: space-between;
  }

  label {
    color: #3d4b5e;
    display: grid;
    gap: 6px;
    font-size: 13px;
  }

  .icon,
  .ghost {
    background: #edf3f7;
    box-shadow: none;
    color: #162033;
  }

  .icon {
    min-height: 34px;
    padding: 0;
    width: 34px;
  }
</style>

<div class="modal" role="dialog" aria-modal="true" aria-label="Company editor">
  <form class="editor" onsubmit={props.persistCompany}>
    <header>
      <h2>{() => (props.draft().name ? "Edit company" : "New company")}</h2>
      <button type="button" class="icon" aria-label="Close company editor" onclick={props.close}>x</button>
    </header>
    <label>Name<input value={() => props.draft().name} oninput={event => props.setDraft({ ...props.draft(), name: event.target.value })} /></label>
    <label>Segment<input value={() => props.draft().segment} oninput={event => props.setDraft({ ...props.draft(), segment: event.target.value })} /></label>
    <label>Owner<input value={() => props.draft().owner} oninput={event => props.setDraft({ ...props.draft(), owner: event.target.value })} /></label>
    <footer>
      <button type="button" class="ghost" onclick={props.close}>Cancel</button>
      <button disabled={props.busy}>{() => props.busy() ? "Saving..." : "Save company"}</button>
    </footer>
  </form>
</div>
